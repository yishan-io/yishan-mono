{
  "name": "@yishan-io/api-service",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:bun": "bun --watch src/server.ts",
    "clean:wrangler": "node -e \"require('node:fs').rmSync('.wrangler', { recursive: true, force: true })\"",
    "dev:worker": "bun run clean:wrangler && wrangler dev",
    "db:local": "docker compose up -d postgres",
    "start": "bun run src/server.ts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "deploy:worker": "wrangler deploy"
  },
  "dependencies": {
    "@yishan-io/core": "workspace:*",
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.44.6",
    "hono": "^4.10.1",
    "http-status-codes": "^2.3.0",
    "pg": "^8.16.3",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260417.0",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.7",
    "typescript": "^5.8.3",
    "wrangler": "4.84.1"
  }
}
