{{.Marker}}
// Installs Pi lifecycle hooks for Yishan notifications.
export default function setup(pi: any) {
  const notifyPath = {{.NotifyPathLiteral}};
  const command = {{printf "%q" .NotifyCommand}};
  const argPrefix = {{.ArgPrefixLiteral}} as string[];

  const isManagedTerminal = Boolean(
    process?.env?.YISHAN_TERMINAL_ID ||
      process?.env?.YISHAN_TAB_ID ||
      process?.env?.YISHAN_PANE_ID,
  );
  if (!isManagedTerminal) return;

  const fire = (eventName: string) => {
    try {
      const { spawn } = require("node:child_process");
      void notifyPath;
      const args = [...argPrefix, eventName];
      const child = spawn(command, args, {
        stdio: ["ignore", "ignore", "ignore"],
        detached: true,
        env: process.env,
      });
      child.on("error", () => {});
      child.unref();
    } catch {
      // no-op
    }
  };

  const skip = (ctx: { hasUI?: boolean }) => ctx?.hasUI === false;

  pi.on("before_agent_start", (_event: unknown, ctx: { hasUI?: boolean }) => {
    if (skip(ctx)) return;
    fire("Start");
  });

  pi.on("tool_execution_end", (_event: unknown, ctx: { hasUI?: boolean }) => {
    if (skip(ctx)) return;
    fire("PostToolUse");
  });

  pi.on("agent_end", (_event: unknown, ctx: { hasUI?: boolean }) => {
    if (skip(ctx)) return;
    fire("Stop");
  });

  pi.on("session_shutdown", (_event: unknown, ctx: { hasUI?: boolean }) => {
    if (skip(ctx)) return;
    fire("Stop");
  });
}
