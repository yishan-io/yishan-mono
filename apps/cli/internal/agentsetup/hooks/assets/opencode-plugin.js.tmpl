{{.PluginMarker}}
export const YishanNotifyPlugin = async ({ $, client }) => {
  if (globalThis.__yishanOpencodeNotifyPluginV1) return {};
  globalThis.__yishanOpencodeNotifyPluginV1 = true;

  if (!process?.env?.{{.TabIDEnvKey}}) return {};

  const notifyPath = {{.NotifyPathLiteral}};
  let currentState = "idle";
  let rootSessionId = null;
  let stopSent = false;
  let waitingInputSent = false;
  let stopTimer = null;

  const STOP_DEBOUNCE_MS = 2500;

  const notify = async (hookEventName) => {
    try {
      {{.NotifyCommand}}
    } catch {
      // fail-open
    }
  };

  const isChildSession = async (sessionId) => {
    if (!sessionId || !client?.session?.list) {
      return true;
    }
    try {
      const sessions = await client.session.list();
      const session = sessions.data?.find((value) => value.id === sessionId);
      return !!session?.parentID;
    } catch {
      return true;
    }
  };

  const handleBusy = async (sessionId) => {
    // Cancel any pending Stop debounce — a new task started before it fired.
    if (stopTimer !== null) {
      clearTimeout(stopTimer);
      stopTimer = null;
      // Reset so this new task can emit its own Start/Stop pair.
      stopSent = false;
      currentState = "idle";
    }
    if (!rootSessionId) {
      rootSessionId = sessionId;
    }
    if (sessionId !== rootSessionId) {
      return;
    }
    if (currentState === "idle") {
      currentState = "busy";
      stopSent = false;
      waitingInputSent = false;
      await notify("Start");
    }
  };

  const handleStop = async (sessionId) => {
    if (rootSessionId && sessionId !== rootSessionId) {
      return;
    }
    if ((currentState === "busy" || currentState === "waiting") && !stopSent) {
      currentState = "idle";
      stopSent = true;
      waitingInputSent = false;
      // Debounce: wait before emitting Stop in case the next task starts immediately
      // (e.g. opencode todo list runs sequential root sessions back-to-back).
      // If handleBusy fires within the window the timer is cancelled and no Stop is sent.
      rootSessionId = null;
      stopTimer = setTimeout(async () => {
        stopTimer = null;
        await notify("Stop");
      }, STOP_DEBOUNCE_MS);
    }
  };

  const handleWaitingInput = async () => {
    if (waitingInputSent) return;
    currentState = "waiting";
    waitingInputSent = true;
    await notify("PermissionRequest");
  };

  const handleWaitingInputResolved = async () => {
    if (currentState !== "waiting") return;
    currentState = "busy";
    waitingInputSent = false;
    stopSent = false;
    await notify("Start");
  };

  return {
    event: async ({ event }) => {
      const sessionId = event.properties?.sessionID;
      if (await isChildSession(sessionId)) {
        return;
      }

      if (event.type === "session.status") {
        const status = event.properties?.status;
        if (status?.type === "busy") {
          await handleBusy(sessionId);
        } else if (status?.type === "idle") {
          await handleStop(sessionId);
        }
      }

      if (event.type === "session.busy") {
        await handleBusy(sessionId);
      }
      if (event.type === "session.idle") {
        await handleStop(sessionId);
      }
      if (event.type === "session.error") {
        if (stopTimer !== null) {
          clearTimeout(stopTimer);
          stopTimer = null;
        }
        currentState = "idle";
        stopSent = true;
        waitingInputSent = false;
        rootSessionId = null;
        stopTimer = setTimeout(async () => {
          stopTimer = null;
          await notify("Failed");
        }, STOP_DEBOUNCE_MS);
      }
      if (event.type === "permission.asked" || event.type === "question.asked") {
        await handleWaitingInput();
      }
      if (event.type === "permission.replied" || event.type === "question.replied" || event.type === "question.rejected") {
        await handleWaitingInputResolved();
      }
    },
    "permission.ask": async (_permission, output) => {
      if (output?.status === "ask") {
        await handleWaitingInput();
      }
    },
    "permission.asked": async () => {
      await handleWaitingInput();
    },
    "permission.replied": async () => {
      await handleWaitingInputResolved();
    },
  };
};
