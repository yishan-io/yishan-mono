#!/usr/bin/env bash
# yishan wrapper for opencode

set -u

readonly WRAPPER_BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=../lib/common.sh
source "${WRAPPER_BIN_DIR}/../lib/common.sh"
if [ -f "${WRAPPER_BIN_DIR}/../lib/hook_ingress.sh" ]; then
  # shellcheck source=../lib/hook_ingress.sh
  source "${WRAPPER_BIN_DIR}/../lib/hook_ingress.sh"
else
  notify_event() { :; }
fi

MANAGED_BIN_DIR="$(resolve_managed_bin_dir)"
REAL_BIN="$(resolve_real_binary "opencode" "$WRAPPER_BIN_DIR" "$MANAGED_BIN_DIR" || true)"
if [ -z "$REAL_BIN" ]; then
  echo "yishan wrapper: real opencode not found in PATH" >&2
  exit 127
fi

if [ -n "${MANAGED_BIN_DIR:-}" ]; then
  managed_bin_dir="${MANAGED_BIN_DIR%/}"
  if [[ "$managed_bin_dir" == */bin ]]; then
    managed_root_dir="${managed_bin_dir%/bin}"
    export OPENCODE_CONFIG_DIR="${managed_root_dir}/opencode-config-home"
  fi
fi

opencode_terminal_emitted=0
emit_terminal_once() {
  local event_name="${1:-Stop}"
  if [ "${opencode_terminal_emitted}" -eq 1 ]; then
    return 0
  fi
  opencode_terminal_emitted=1
  notify_event "opencode" "$event_name"
}

handle_interrupt() {
  local signal="$1"
  emit_terminal_once "Failed"
  trap - "$signal"
  kill -s "$signal" "$$"
}

trap 'handle_interrupt INT' INT
trap 'handle_interrupt TERM' TERM

"$REAL_BIN" "$@"
status=$?

if [ "$status" -eq 0 ]; then
  emit_terminal_once "Stop"
else
  emit_terminal_once "Failed"
fi
exit "$status"
