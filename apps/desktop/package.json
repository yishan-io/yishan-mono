{
  "name": "@yishan-io/desktop",
  "version": "0.1.0",
  "description": "Yishan desktop application",
  "homepage": "https://github.com/yishan-io/yishan-mono",
  "author": {
    "name": "Yishan",
    "email": "support@yishan.io"
  },
  "type": "module",
  "main": "dist/electron/main.cjs",
  "scripts": {
    "start": "vite build && bun run electron:build && electron dist/electron/main.cjs",
    "dev": "bun run dev:hmr",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run electron:watch:main\" \"bun run electron:watch:preload\" \"bun run electron:dev\"",
    "hmr": "vite --host 127.0.0.1 --port 5173",
    "build": "vite build && bun run electron:build",
    "cli:build": "node scripts/buildCliBinary.mjs",
    "build:app": "bun run cli:build && bun run build && node scripts/packageApp.mjs --publish never",
    "build:app:dir": "bun run cli:build && bun run build && node scripts/packageApp.mjs --dir --publish never",
    "electron:build": "bun run electron:build:main && bun run electron:build:preload",
    "electron:build:main": "esbuild src/main/main.ts --bundle --platform=node --format=cjs --outfile=dist/electron/main.cjs --external:electron --external:electron-updater --external:@earendil-works/pi-coding-agent --external:@earendil-works/pi-ai",
    "electron:build:preload": "esbuild src/main/preload.ts --bundle --platform=node --format=cjs --outfile=dist/electron/preload.js --external:electron",
    "electron:watch:main": "esbuild src/main/main.ts --bundle --platform=node --format=cjs --outfile=dist/electron/main.cjs --external:electron --external:electron-updater --external:@earendil-works/pi-coding-agent --external:@earendil-works/pi-ai --watch",
    "electron:watch:preload": "esbuild src/main/preload.ts --bundle --platform=node --format=cjs --outfile=dist/electron/preload.js --external:electron --watch",
    "electron:dev": "cross-env ELECTRON_CHANNEL=dev NODE_ENV=development ELECTRON_RENDERER_URL=http://127.0.0.1:5173 wait-on tcp:5173 file:dist/electron/main.cjs file:dist/electron/preload.js && cross-env ELECTRON_CHANNEL=dev NODE_ENV=development ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron dist/electron/main.cjs",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.4",
    "@mui/x-charts": "^9.4.0",
    "@pierre/diffs": "^1.2.8",
    "@pierre/theme": "1.1.0",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-virtual": "^3.13.24",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-fonts": "^0.1.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "@yishan-io/core": "workspace:*",
    "@yishan-io/design-tokens": "workspace:*",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "highlight.js": "^11.11.1",
    "hotkeys-js": "^4.0.3",
    "i18next": "^26.0.6",
    "immer": "^11.1.4",
    "jsdom": "^29.0.2",
    "material-icon-theme": "^5.33.1",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.52.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.2",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "dev.yishan.desktop",
    "productName": "Yishan",
    "beforePack": "./scripts/beforePack.mjs",
    "icon": "src/assets/images/yishan-app-icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "src/assets/notification-sounds/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/resources",
        "to": ".",
        "filter": [
          "yishan",
          "yishan.exe"
        ]
      }
    ],
    "mac": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "category": "public.app-category.developer-tools",
      "icon": "src/assets/icons/yishan.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Yishan uses the microphone to transcribe voice input into agent prompts."
      },
      "notarize": true
    },
    "win": {
      "icon": "src/assets/images/yishan-app-icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "src/assets/images/yishan-app-icon.png",
      "executableName": "yishan",
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "extraMetadata": {
      "main": "dist/electron/main.cjs"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "yishan-io",
        "repo": "yishan-mono",
        "releaseType": "draft",
        "tagNamePrefix": "v"
      }
    ],
    "protocols": [
      {
        "name": "Yishan",
        "schemes": [
          "yishan"
        ]
      }
    ]
  },
  "license": "Elastic-2.0",
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "electron-updater": "^6.8.3"
  }
}
