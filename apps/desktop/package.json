{
  "name": "@yishan/desktop",
  "version": "0.1.0",
  "description": "Yishan desktop application",
  "type": "module",
  "main": "dist/electron/main.cjs",
  "scripts": {
    "start": "vite build && bun run electron:build && electron dist/electron/main.cjs",
    "dev": "bun run dev:hmr",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run electron:watch:main\" \"bun run electron:watch:preload\" \"bun run electron:dev\"",
    "hmr": "vite --host 127.0.0.1 --port 5173",
    "build": "vite build && bun run electron:build",
    "cli:build": "node scripts/buildCliBinary.mjs",
    "build:app": "bun run cli:build && bun run build && electron-builder --publish never",
    "build:app:dir": "bun run cli:build && bun run build && electron-builder --dir --publish never",
    "electron:build": "bun run electron:build:main && bun run electron:build:preload",
    "electron:build:main": "esbuild src/main/main.ts --bundle --platform=node --format=cjs --outfile=dist/electron/main.cjs --external:electron --external:electron-updater",
    "electron:build:preload": "esbuild src/main/preload.ts --bundle --platform=node --format=cjs --outfile=dist/electron/preload.js --external:electron",
    "electron:watch:main": "esbuild src/main/main.ts --bundle --platform=node --format=cjs --outfile=dist/electron/main.cjs --external:electron --external:electron-updater --watch",
    "electron:watch:preload": "esbuild src/main/preload.ts --bundle --platform=node --format=cjs --outfile=dist/electron/preload.js --external:electron --watch",
    "electron:dev": "cross-env ELECTRON_CHANNEL=dev NODE_ENV=development ELECTRON_RENDERER_URL=http://127.0.0.1:5173 wait-on tcp:5173 file:dist/electron/main.cjs file:dist/electron/preload.js && cross-env ELECTRON_CHANNEL=dev NODE_ENV=development ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron dist/electron/main.cjs",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@codemirror/lang-angular": "^0.1.4",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-less": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sass": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-vue": "^0.1.3",
    "@codemirror/lang-wast": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@git-diff-view/file": "^0.1.3",
    "@git-diff-view/react": "^0.1.3",
    "@lezer/highlight": "^1.2.3",
    "@mui/material": "^7.3.4",
    "@mui/x-tree-view": "^9.0.2",
    "@tanstack/react-query": "^5.100.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-fonts": "^0.1.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "@yishan/design-tokens": "workspace:*",
    "codemirror": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "hotkeys-js": "^4.0.3",
    "i18next": "^26.0.6",
    "immer": "^11.1.4",
    "jsdom": "^29.0.2",
    "material-icon-theme": "^5.33.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "dev.yishan.desktop",
    "productName": "Yishan",
    "icon": "src/assets/images/yishan-app-icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/resources",
        "to": ".",
        "filter": [
          "yishan",
          "yishan.exe"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "icon": "src/assets/icons/yishan.icns"
    },
    "win": {
      "icon": "src/assets/images/yishan-app-icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "src/assets/images/yishan-app-icon.png",
      "target": [
        "AppImage"
      ]
    },
    "extraMetadata": {
      "main": "dist/electron/main.cjs"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "yishan-io",
        "repo": "yishan-mono"
      }
    ]
  },
  "license": "Elastic-2.0",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0"
  }
}
